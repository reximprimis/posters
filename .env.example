# Skopiuj do .env i uzupełnij klucze. Wszystkie zmienne używane przez projekt — źródło prawdy obok kodu.

# --- OpenAI (generator obrazów + domyślnie prompty) ---
OPENAI_API_KEY=
OPENAI_PROMPT_MODEL=gpt-4o-mini
IMAGE_GENERATION_MODEL=gpt-image-2
IMAGE_GENERATION_SIZE=1024x1536
IMAGE_GENERATION_QUALITY=high
IMAGE_GENERATION_FORMAT=png
IMAGE_GENERATION_BACKGROUND=opaque
IMAGE_GENERATION_MODERATION=auto
# Transient API errors (e.g. 520 on 2nd image in a batch): retries with backoff
IMAGE_GENERATION_MAX_ATTEMPTS=4
IMAGE_GENERATION_RETRY_DELAY_MS=4000
# Rozmiar obrazu z API (tymczasowy plik .gen.tmp.png przed upscale do druku).
IMAGE_TARGET_WIDTH=2000
IMAGE_TARGET_HEIGHT=2857
# Safe print framing w promptach (inner 90%, outer 5% tylko tło).
ENABLE_SAFE_FRAMING=1
# Nie zapisuj trwałych masterów — tylko tymczasowy .gen.tmp.png (usuwany po upscale).
KEEP_MASTER_IMAGES=false
# Deprecated alias (ignored when KEEP_MASTER_IMAGES=false).
ENABLE_MASTER_SAVE=0
SAFE_MARGIN_PERCENT=0.05
SUBJECT_SCALE_MIN=0.70
SUBJECT_SCALE_MAX=0.80
# Automatyczny upscale temp PNG → final PNG przy zapisie do biblioteki: 50x70 cm @ 300 DPI.
POSTER_UPSCALE_ON_SAVE=1
POSTER_UPSCALE_SHORT_EDGE=5906
POSTER_UPSCALE_LONG_EDGE=8268

# --- Anthropic (prompty gdy wybierzesz Claude w UI) ---
ANTHROPIC_API_KEY=
# Przy obu kluczach: openai | anthropic
PROMPT_LLM=openai

# --- design-md / getdesign.md ---
DESIGN_MD_SLUG=claude
DESIGN_MD_URL=
DESIGN_MD_MAX_CHARS=6000

# --- Opcjonalne ---
GEMINI_API_KEY=
REPLICATE_API_KEY=
CANVA_API_KEY=
CANVA_API_SECRET=

# --- Aplikacja (preview) ---
PORT=3000
OUTPUT_DIR=./posters
SHOPIFY_IMAGE_BASE_URL=https://cdn.jsdelivr.net/gh/reximprimis/posters@main/shopify_thumbs

# --- Shopify Headless (Storefront API: porownanie live sklepu vs lokalne inventory) ---
# Przyklad: reximprimis-headless-03.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Publiczny Storefront access token z "Manage API access" -> Storefront API
SHOPIFY_STOREFRONT_API_TOKEN=
# Wersja Storefront API, np. 2025-10
SHOPIFY_STOREFRONT_API_VERSION=2025-10

# --- Passe-partout (ramka PNG; margin = ułamek krótszego boku, 0.02–0.22) ---
POSTER_MAT_COLOR=#ffffff
POSTER_MAT_MARGIN_RATIO=0.116
POSTER_MAT_BOTTOM_WEIGHT=1.82

# --- Mockup wnętrza (Sharp: szablon + plakat, bez AI) ---
# Opcjonalny JPG/PNG ściany — ścieżka względem root projektu lub absolutna. Puste = szary syntetyczny „pokój”.
LIFESTYLE_MOCKUP_TEMPLATE=
# Slot na plakat (ułamki szablonu): lewo, góra, szer., wys. Dopasuj do LIFESTYLE_MOCKUP_TEMPLATE lub syntetycznej ściany.
LIFESTYLE_INSET=0.22,0.06,0.56,0.58
# 1 = mockup PNG w proporcji plakatu (np. 7:10); 0 = zostaw rozmiar szablonu. Mockup nie generuje PDF — tylko sklep.
LIFESTYLE_PDF_NORMALIZE=1
