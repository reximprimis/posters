# Skopiuj do .env i uzupełnij klucze. Wszystkie zmienne używane przez projekt — źródło prawdy obok kodu.

# --- OpenAI (DALL-E + domyślnie prompty) ---
OPENAI_API_KEY=
OPENAI_PROMPT_MODEL=gpt-4o-mini
DALLE_IMAGE_STYLE=vivid
DALLE_IMAGE_SIZE=1024x1792

# --- Anthropic (prompty gdy wybierzesz Claude w UI) ---
ANTHROPIC_API_KEY=
# Przy obu kluczach: openai | anthropic
PROMPT_LLM=openai

# --- design-md / getdesign.md ---
DESIGN_MD_SLUG=claude
DESIGN_MD_URL=
DESIGN_MD_MAX_CHARS=6000

# --- Opcjonalne ---
GEMINI_API_KEY=
REPLICATE_API_KEY=
CANVA_API_KEY=
CANVA_API_SECRET=

# --- Aplikacja (preview) ---
PORT=3000
OUTPUT_DIR=./posters

# --- Passe-partout (ramka PNG; margin = ułamek krótszego boku, 0.02–0.22) ---
POSTER_MAT_COLOR=#ffffff
POSTER_MAT_MARGIN_RATIO=0.116
POSTER_MAT_BOTTOM_WEIGHT=1.82
